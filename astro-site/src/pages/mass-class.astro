---
import Layout from "../layouts/Layout.astro";
import SelectBar from "../components/SelectBar.astro";
---

<Layout title="プロ講師指導塾｜集団授業">
<!-- ===== Group Class Page ===== -->
<section class="group-wrap" id="top">

  <!-- Hero -->
  <header class="group-hero-title">
  <p class="group-kicker">学習管理 × 少人数クラス</p>
    <h1 class="group-h1">
      集団授業</h1>
    <p class="group-lead">
      正しい計画で成績を伸ばす<br>
      「学習管理」の集団授業
    </p>
  </header>
  
  <header class="group-hero">
    <div class="group-pill-title">
      基本情報
    </div>
    <div class="group-pill" aria-label="基本情報">
      <strong>1年間で英語数学の高校課程全範囲網羅<br>
      1クラス最大8名<br>
      1講義120分</strong>
    </div>

    <div class="group-cta">
      <a class="group-btn primary" href="#cta">入塾相談</a>
    </div>

    <!-- ページ内ナビ（対象・科目・年間・料金） -->
    <nav class="group-nav" aria-label="ページ内リンク">
      <a href="#target">対象</a>
      <a href="#subjects">開講講座</a>
      <a href="#year">年間スケジュール</a>
      <a href="#fee">受講費用</a>
    </nav>
  </header>


  <!-- ===== 対象 ===== -->
  <section class="group-section" id="subjects">
    <h2 class="group-h2">対象</h2>
    
    <div class="group-card">
      <h3 class="group-h3">高校生全学年＋大学受験生</h3>
      <ul class="group-list">
        <li>将来、国公立・関関同立を目指している</li>
        <li>勉強方法を根本から見直したい</li>
        <li>学校の進度ではなく、受験基準で力をつけたい</li>
        <li>「やるべきこと」が曖昧で、学習がブレやすい</li>
      </ul>
      <div class="group-note">
        <div class="group-note-title">全学年対象</div>
        <p>初学からでも1年で大学受験レベルになれるカリキュラムとなっています。</p>
      </div>
    </div>
  </section>


  <!-- ===== 科目（折りたたみ） ===== -->
  <section class="group-section" id="subjects">
    <h2 class="group-h2">開講講座</h2>

    <details class="group-acc">
      <summary class="group-sum">
        <span class="group-sum-title">数学</span>
        <span class="group-sum-tag">マーク → 記述</span>
      </summary>
      
      <div class="group-body">
        <dl class="group-dl">
          <div class="group-row">
            <dt>前期の学習内容</dt>
            <dd>
              <ol class="curriculum-grid" aria-label="前期カリキュラム 16テーマ">
                <div class="cur-title">文理共通</div>
                <li class="cur-item">
                  <span class="cur-no">01</span>
                  <div class="cur-body">
                    <div class="cur-subject">数学Ⅰ</div>
                    <div class="cur-topic">数と式</div>
                  </div>
                </li>
              
                <li class="cur-item">
                  <span class="cur-no">02</span>
                  <div class="cur-body">
                    <div class="cur-subject">数学Ⅰ</div>
                    <div class="cur-topic">集合と命題</div>
                  </div>
                </li>

                <li class="cur-item">
                  <span class="cur-no">03</span>
                  <div class="cur-body">
                    <div class="cur-subject">数学Ⅰ</div>
                    <div class="cur-topic">2次関数</div>
                  </div>
                </li>

                <li class="cur-item">
                  <span class="cur-no">04</span>
                  <div class="cur-body">
                    <div class="cur-subject">数学Ⅰ</div>
                    <div class="cur-topic">図形と計量</div>
                  </div>
                </li>

                <li class="cur-item">
                  <span class="cur-no">05</span>
                  <div class="cur-body">
                    <div class="cur-subject">数学Ⅰ</div>
                    <div class="cur-topic">データ分析</div>
                  </div>
                </li>

                <li class="cur-item">
                  <span class="cur-no">06</span>
                  <div class="cur-body">
                    <div class="cur-subject">数学A</div>
                    <div class="cur-topic">整数</div>
                  </div>
                </li>

                <li class="cur-item">
                  <span class="cur-no">07</span>
                  <div class="cur-body">
                    <div class="cur-subject">数学A</div>
                    <div class="cur-topic">場合の数と確率</div>
                  </div>
                </li>

                <li class="cur-item">
                  <span class="cur-no">08</span>
                  <div class="cur-body">
                    <div class="cur-subject">数学A</div>
                    <div class="cur-topic">図形の性質</div>
                  </div>
                </li>

                <li class="cur-item">
                  <span class="cur-no">09</span>
                  <div class="cur-body">
                    <div class="cur-subject">数学Ⅱ</div>
                    <div class="cur-topic">式と証明</div>
                  </div>
                </li>

                <li class="cur-item">
                  <span class="cur-no">10</span>
                  <div class="cur-body">
                    <div class="cur-subject">数学Ⅱ</div>
                    <div class="cur-topic">複素数と高次方程式</div>
                  </div>
                </li>

                <li class="cur-item">
                  <span class="cur-no">11</span>
                  <div class="cur-body">
                    <div class="cur-subject">数学Ⅱ</div>
                    <div class="cur-topic">図形と方程式</div>
                  </div>
                </li>

                <li class="cur-item">
                  <span class="cur-no">12</span>
                  <div class="cur-body">
                    <div class="cur-subject">数学Ⅱ</div>
                    <div class="cur-topic">三角関数</div>
                  </div>
                </li>

                <li class="cur-item">
                  <span class="cur-no">13</span>
                  <div class="cur-body">
                    <div class="cur-subject">数学Ⅱ</div>
                    <div class="cur-topic">指数対数</div>
                  </div>
                </li>

                <li class="cur-item">
                  <span class="cur-no">14</span>
                  <div class="cur-body">
                    <div class="cur-subject">数学Ⅱ</div>
                    <div class="cur-topic">微分積分</div>
                  </div>
                </li>

                <li class="cur-item">
                  <span class="cur-no">15</span>
                  <div class="cur-body">
                    <div class="cur-subject">数学B</div>
                    <div class="cur-topic">数列</div>
                  </div>
                </li>

                <li class="cur-item">
                  <span class="cur-no">16</span>
                  <div class="cur-body">
                    <div class="cur-subject">数学演習</div>
                    <div class="cur-topic">総合演習</div>
                  </div>
                </li>
              </ol>
            </dd>
          </div>

          <div class="group-row">
            <dt>夏期の学習内容</dt>
            <dd>  
              <ol class="curriculum-grid" aria-label="夏期カリキュラム 理系8テーマ 文系4テーマ">
                <div class="cur-title">文系数学</div>
                <li class="cur-item">
                  <span class="cur-no">01</span>
                  <div class="cur-body">
                    <div class="cur-subject">数学B(統計と推測)</div>
                    <div class="cur-topic">確率変数と二項分布</div>
                  </div>
                </li>
              
                <li class="cur-item">
                  <span class="cur-no">02</span>
                  <div class="cur-body">
                    <div class="cur-subject">数学B(統計と推測)</div>
                    <div class="cur-topic">正規分布</div>
                  </div>
                </li>
              
                <li class="cur-item">
                  <span class="cur-no">03</span>
                  <div class="cur-body">
                    <div class="cur-subject">数学B(統計と推測)</div>
                    <div class="cur-topic">標本調査</div>
                  </div>
                </li>
              
                <li class="cur-item">
                  <span class="cur-no">04</span>
                  <div class="cur-body">
                    <div class="cur-subject">数学B(統計と推測)</div>
                    <div class="cur-topic">仮説検定</div>
                  </div>
                </li>
              
                <div class="cur-title">理系数学</div>
                <li class="cur-item">
                  <span class="cur-no">01</span>
                  <div class="cur-body">
                    <div class="cur-subject">数学Ⅲ</div>
                    <div class="cur-topic">極限値</div>
                  </div>
                </li>
              
                <li class="cur-item">
                  <span class="cur-no">02</span>
                  <div class="cur-body">
                    <div class="cur-subject">数学Ⅲ</div>
                    <div class="cur-topic">関数の極限</div>
                  </div>
                </li>

                <li class="cur-item">
                  <span class="cur-no">03</span>
                  <div class="cur-body">
                    <div class="cur-subject">数学Ⅲ</div>
                    <div class="cur-topic">微分法</div>
                  </div>
                </li>

                <li class="cur-item">
                  <span class="cur-no">04</span>
                  <div class="cur-body">
                    <div class="cur-subject">数学Ⅲ</div>
                    <div class="cur-topic">微分計算</div>
                  </div>
                </li>

                <li class="cur-item">
                  <span class="cur-no">05</span>
                  <div class="cur-body">
                    <div class="cur-subject">数学Ⅲ</div>
                    <div class="cur-topic">積分法</div>
                  </div>
                </li>

                <li class="cur-item">
                  <span class="cur-no">06</span>
                  <div class="cur-body">
                    <div class="cur-subject">数学Ⅲ</div>
                    <div class="cur-topic">積分計算</div>
                  </div>
                </li>

                <li class="cur-item">
                  <span class="cur-no">07</span>
                  <div class="cur-body">
                    <div class="cur-subject">数学Ⅲ</div>
                    <div class="cur-topic">微積応用</div>
                  </div>
                </li>

                <li class="cur-item">
                  <span class="cur-no">08</span>
                  <div class="cur-body">
                    <div class="cur-subject">数学Ⅲ</div>
                    <div class="cur-topic">総合演習</div>
                  </div>
                </li>
              </ol>
            </dd>
          </div>

          <div class="group-row">
            <dt>後期の学習内容</dt>
            <dd>  
              <ol class="curriculum-grid" aria-label="後期カリキュラム ">
                <div class="cur-title">文理共通</div>
                <li class="cur-item">
                  <span class="cur-no">01</span>
                  <div class="cur-body">
                    <div class="cur-subject">数学C</div>
                    <div class="cur-topic">平面ベクトル</div>
                  </div>
                </li>

                <li class="cur-item">
                  <span class="cur-no">02</span>
                  <div class="cur-body">
                    <div class="cur-subject">数学C</div>
                    <div class="cur-topic">空間ベクトル</div>
                  </div>
                </li>

                <li class="cur-item">
                  <span class="cur-no">03</span>
                  <div class="cur-body">
                    <div class="cur-subject">数学C</div>
                    <div class="cur-topic">ベクトル応用</div>
                  </div>
                </li>

                <div class="cur-title">文系数学</div>
                <li class="cur-item">
                  <span class="cur-no">04~16</span>
                  <div class="cur-body">
                    <div class="cur-subject">数学ⅠAⅡB+ベクトル</div>
                    <div class="cur-topic">単元別演習</div>
                  </div>
                </li>

                <div class="cur-title">理系数学</div>
                <li class="cur-item">
                  <span class="cur-no">04</span>
                  <div class="cur-body">
                    <div class="cur-subject">数学C</div>
                    <div class="cur-topic">複素数平面</div>
                  </div>
                </li>

                <li class="cur-item">
                  <span class="cur-no">05</span>
                  <div class="cur-body">
                    <div class="cur-subject">数学C</div>
                    <div class="cur-topic">複素数の極形式と回転</div>
                  </div>
                </li>

                <li class="cur-item">
                  <span class="cur-no">06</span>
                  <div class="cur-body">
                    <div class="cur-subject">数学C</div>
                    <div class="cur-topic">複素数平面応用</div>
                  </div>
                </li>

                <li class="cur-item">
                  <span class="cur-no">07</span>
                  <div class="cur-body">
                    <div class="cur-subject">数学C</div>
                    <div class="cur-topic">式と曲線</div>
                  </div>
                </li>

                <li class="cur-item">
                  <span class="cur-no">08</span>
                  <div class="cur-body">
                    <div class="cur-subject">数学C</div>
                    <div class="cur-topic">式と曲線の応用</div>
                  </div>
                </li>

                <li class="cur-item">
                  <span class="cur-no">09~16</span>
                  <div class="cur-body">
                    <div class="cur-subject">数学ⅠAⅡBC</div>
                    <div class="cur-topic">単元別演習</div>
                  </div>
                </li>
              </ol>
            </dd>
          </div>

          <div class="group-row">
            <dt>直前期の内容</dt>
            <dd>
              志望校別の過去問演習<br>
              授業回数: 各4回
            </dd>
          </div>
          <p class="group-caption">※ 授業進度は状況に応じて前後します</p>
        </dl>
      </div>
    </details>
    
    
    <details class="group-acc">
      <summary class="group-sum">
        <span class="group-sum-title">英語</span>
        <span class="group-sum-tag">文法 → 長文 → 英作</span>
      </summary>
      <div class="group-body">
        <dl class="group-dl">
          <div class="group-row">
            <dt>前期</dt>
            <dd>文法・選択問題・整序を中心に「得点の土台」を固めます。</dd>
          </div>
          <div class="group-row">
            <dt>夏期</dt>
            <dd>比較的易しめの長文演習で、読解の型を身につけます。</dd>
          </div>
          <div class="group-row">
            <dt>後期</dt>
            <dd>難関私立・国公立を見据え、記述対策と長文対策を強化します。</dd>
          </div>
          <div class="group-row">
            <dt>直前期</dt>
            <dd>志望校別の過去問演習で、合格点まで引き上げます。</dd>
          </div>
        </dl>
      </div>
    </details>
  </section>


  <!-- ===== 年間スケジュール（前半・後半で分割） ===== -->
  <section class="group-section" id="year">
    <h2 class="group-h2">年間スケジュール</h2>

    <div class="group-grid-2">
      <article class="group-card">
        <div class="group-month">
          <span class="group-badge">3月</span><span class="group-mtxt">春期講習</span>
        </div>

        <div class="group-month group-month-wide">
          <span class="group-badge wide">4〜7月</span>
          <span class="group-mtxt">前期授業（全16講義）</span>
        </div>

        <div class="group-month">
          <span class="group-badge">8月</span><span class="group-mtxt">夏期講習</span>
        </div>

        <div class="group-month group-month-wide">
          <span class="group-badge wide">9〜12月</span>
          <span class="group-mtxt">後期授業（全16講義）</span>
        </div>

        <div class="group-month">
          <span class="group-badge">1月</span><span class="group-mtxt">冬期講習</span>
        </div>

        <div class="group-month">
          <span class="group-badge">2月</span><span class="group-mtxt">直前期（志望校別演習）</span>
        </div>
      </article>
    </div>
  </section>

  <section class="group-section" id="year">
    <h2 class="group-h2">入塾までの流れ</h2>

    <div class="group-grid-2">
      <article class="group-card">
    <div class="group-grid-2">
      <article class="group-card">
        <div class="group-month">
          <span class="group-badge">1</span>
          <span class="group-mtxt">LINEで相談</span>
        </div>

        <div class="group-month group-month">
          <span class="group-badge">2</span>
          <span class="group-mtxt">授業参加日を決定</span>
        </div>

        <div class="group-month">
          <span class="group-badge">3</span>
          <span class="group-mtxt">お試し費用振込</span>
        </div>

        <div class="group-month group-month">
          <span class="group-badge">4</span>
          <span class="group-mtxt">お試し授業開始</span>
        </div>

        <div class="group-month">
          <span class="group-badge">5</span>
          <span class="group-mtxt">入塾</span>
        </div>

        <div class="group-month">
          <span class="group-badge">6</span>
          <span class="group-mtxt">今まで通り授業を受ける</span>
        </div>
      </article>
    </div>
      </article>
    </div>
  </section>


  <!-- ===== 料金 ===== -->
  <section class="group-section" id="fee">
    <div class="group-head">
      <h2 class="group-h2">受講費用</h2>
    </div>

    <div class="group-card">
      <dl class="group-dl fee">
        <div class="group-row">
          <dt>1ヶ月お試し費用</dt>
          <dd>1教科あたり <strong>28,000円</strong>
          </dd>
        </div>
        
        <div class="group-row">
          <dt>授業料</dt>
          <dd>1時間あたり <strong>3,500円</strong>
            <p class="group-caption">※ 1講義は基本120分</p>
          </dd>
        </div>
        
        <div class="group-row">
          <dt>各講義費用</dt>
          <dd>
            <div class="fee-title">前期講義と後期講義の費用</div>
            <p class="fee-para">1教科あたり<strong>112,000円</strong></p>
            <div class="fee-title">季節講習の費用</div>
            <p class="fee-para">1教科あたり<strong>28,000円</strong></p>
          </dd>
        </div>
        
        <div class="group-row">
          <dt>入塾金</dt>
          <dd><strong>20,000円</strong>（集団授業）</dd>
        </div>
      </dl>

      <p class="group-note slim">
        ※ 詳細は無料学習相談にてご案内します。
      </p>
    </div>
  </section>


  <!-- ===== CTA ===== -->
  <section class="group-section" id="cta">
    <div class="group-cta-box">
      <h2 class="group-cta-title">入塾相談</h2>
      <p class="group-cta-text">
        公式LINE・メール・電話にて入塾相談受付中
      </p>
      <div class="group-cta-btns">
        <a class="group-btn primary" href="/contact">相談する</a>
      </div>
    </div>
  </section>
</section>
</Layout>
